FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV ENV_DIR=/home/testuser/env
ENV HOME=/home/testuser

RUN apt-get update && apt-get install -y \
    git \
    curl \
    wget \
    zsh \
    bash \
    ca-certificates \
    sudo \
    build-essential \
    jq \
    unzip \
    file \
    python3 \
    python3-pip \
    netcat-openbsd \
    procps \
    tree \
    ripgrep \
    fd-find \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -s /bin/bash testuser && \
    echo "testuser ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

WORKDIR /home/testuser

COPY --chown=testuser:testuser . /home/testuser/env

USER testuser

RUN chmod +x /home/testuser/env/tests/docker/*.sh 2>/dev/null || true
RUN chmod +x /home/testuser/env/tests/docker/lib/*.sh 2>/dev/null || true
RUN chmod +x /home/testuser/env/tests/docker/suites/*.sh 2>/dev/null || true
RUN chmod +x /home/testuser/env/scripts/*.sh 2>/dev/null || true

RUN git config --global user.email "test@test.com" && \
    git config --global user.name "Test User" && \
    git config --global init.defaultBranch master

RUN mkdir -p /home/testuser/env/tmp

ENV PATH="/home/testuser/env/bin:/home/testuser/.local/bin:$PATH"

ENTRYPOINT ["/bin/bash"]
CMD ["/home/testuser/env/tests/docker/run_tests.sh"]
